# Frontend-local ignores. Repo-wide ignores live in ../.gitignore.

# Compiled output
/dist/
/build/
/out-tsc/
/tmp/

# Dependencies
/node_modules/

# Angular / Vite cache
/.angular/cache/
/.vite/
/.cache/

# Test coverage
/coverage/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Environment files
.env
.env.*
!.env.example
!.env.sample
*.local

# IDE/editor files
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/settings.json
.history/

# OS files
.DS_Store
Thumbs.db
Desktop.ini
